  %% Locking
  {default_max_wait_ms,   60000},       %% server-wide wait-queue deadline

  %% Persistence
  {persistence_dir,  "/var/lib/pluto/state"},
  {flush_interval,        60000},       %% ms, or atom minute | hour

  %% Event log
  {event_log_dir,       "/var/lib/pluto/events"},
  {event_log_max_entries,  100000},
  {event_log_retention_days,    7},

  %% Metrics
  {metrics_port,           9100},       %% Prometheus scrape port; 0 to disable

  %% Admin
  {admin_token,        <<"secret">>},   %% required for admin ops and selftest

  %% Authentication
  {agent_tokens, #{                     %% agent_id -> bearer token map
    <<"coder-1">>  => <<"tok-abc">>,
