%% -*- erlang -*-
%% Pluto runtime configuration
[
  {pluto, [
    %% ── Networking ──────────────────────────────────────────────────────
    {tcp_port,               9000},      %% TCP protocol port
    {http_port,              9001},       %% HTTP API port (set to 'disabled' to turn off)
    {tcp_backlog,            128},        %% listen/2 backlog size

    %% ── Session policy ──────────────────────────────────────────────────
    {session_conflict_policy, strict},    %% strict | takeover
    {reconnect_grace_ms,     30000},      %% Lock hold time after disconnect (ms)

    %% ── Heartbeat / liveness ────────────────────────────────────────────
    {heartbeat_interval_ms,  15000},      %% Advertised to clients
    {heartbeat_sweep_ms,      5000},      %% How often sweeper wakes
    {heartbeat_timeout_ms,   30000},      %% Declare session dead after this

    %% ── Locking ─────────────────────────────────────────────────────────
    {default_max_wait_ms,    60000},      %% Server-wide wait-queue deadline

    %% ── Persistence ─────────────────────────────────────────────────────
    {persistence_dir,  "/tmp/pluto/state"},
    {flush_interval,   60000},            %% ms (60000 = 1 minute)

    %% ── Event log ───────────────────────────────────────────────────────
    {event_log_dir,            "/tmp/pluto/events"},
    {event_log_max_entries,    100000},
    {event_log_retention_days, 7},

    %% ── Admin ───────────────────────────────────────────────────────────
    %% Uncomment to require an admin token for admin ops and selftest:
    %% {admin_token, <<"pluto-admin-secret">>},

    %% ── Authentication ──────────────────────────────────────────────────
    %% Uncomment to enable per-agent bearer tokens:
    %% {agent_tokens, #{
    %%     <<"coder-1">>  => <<"tok-abc">>,
    %%     <<"reviewer-2">> => <<"tok-xyz">>
    %% }},

    %% ── ACL (resource access control) ───────────────────────────────────
    %% Uncomment to enable resource ACLs:
    %% {acl, [
    %%     {"coder-*",    "file:/repo/src/*",   [read, write]},
    %%     {"reviewer-*", "file:/repo/src/*",   [read]},
    %%     {"*",          "artifact:build/*",   [read]}
    %% ]}
    {acl, undefined}
  ]},

  {kernel, [
    {logger_level, info},
    {logger, [
      {handler, default, logger_std_h, #{
        formatter => {pluto_json_log, #{}}
      }}
    ]}
  ]}
].
