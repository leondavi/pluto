%% -*- erlang -*-
%% Pluto runtime configuration
[
  {pluto, [
    %% ── Networking ──────────────────────────────────────────────────────
    {tcp_port,               9000},      %% Port Pluto listens on
    {tcp_backlog,            128},        %% listen/2 backlog size

    %% ── Session policy ──────────────────────────────────────────────────
    {session_conflict_policy, strict},    %% strict | takeover
    {reconnect_grace_ms,     30000},      %% Lock hold time after disconnect (ms)

    %% ── Heartbeat / liveness ────────────────────────────────────────────
    {heartbeat_interval_ms,  15000},      %% Advertised to clients
    {heartbeat_sweep_ms,      5000},      %% How often sweeper wakes
    {heartbeat_timeout_ms,   30000},      %% Declare session dead after this

    %% ── Locking ─────────────────────────────────────────────────────────
    {default_max_wait_ms,    60000},      %% Server-wide wait-queue deadline

    %% ── Persistence ─────────────────────────────────────────────────────
    {persistence_dir,  "/tmp/pluto/state"},
    {flush_interval,   60000},            %% ms (60000 = 1 minute)

    %% ── Event log ───────────────────────────────────────────────────────
    {event_log_dir,            "/tmp/pluto/events"},
    {event_log_max_entries,    100000},
    {event_log_retention_days, 7}
  ]}
].
