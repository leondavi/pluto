%% -*- erlang -*-
%% Pluto — Agent Coordination Server
%% rebar3 configuration

{erl_opts, [
    debug_info,
    warnings_as_errors,
    {i, "include"}
]}.

{deps, []}.

%% Release configuration
{relx, [
    {release, {pluto, "0.1.0"}, [pluto]},
    {dev_mode, false},
    {include_erts, true},
    {sys_config, "config/sys.config"},
    {vm_args,    "config/vm.args"},
    {extended_start_script, true}
]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, []}
    ]}
]}.

{shell, [
    {apps, [pluto]},
    {config, "config/sys.config"}
]}.
