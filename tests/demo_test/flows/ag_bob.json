{
  "agent_id": "bob",
  "description": "Bob asks and answers questions, logs to shared transcript",
  "steps": [
    {"action": "wait_message", "from": "alice", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A1] bob -> alice: The capital of France is Paris.\n"},
    {"action": "release"},
    {"action": "send", "to": "alice", "payload": {"type": "answer", "id": "A1", "text": "The capital of France is Paris."}},

    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[Q2] bob -> charlie: What is the tallest mountain in the world?\n"},
    {"action": "release"},
    {"action": "send", "to": "charlie", "payload": {"type": "question", "id": "Q2", "text": "What is the tallest mountain in the world?"}},

    {"action": "wait_message", "from": "charlie", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A2] charlie -> bob: Mount Everest is the tallest mountain.\n"},
    {"action": "release"},

    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[Q7] bob -> diana: What is the boiling point of water?\n"},
    {"action": "release"},
    {"action": "send", "to": "diana", "payload": {"type": "question", "id": "Q7", "text": "What is the boiling point of water?"}},

    {"action": "wait_message", "from": "diana", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A7] diana -> bob: Water boils at 100 degrees Celsius.\n"},
    {"action": "release"},

    {"action": "wait_message", "from": "eve", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A10] bob -> eve: There are 8 planets in our solar system.\n"},
    {"action": "release"},
    {"action": "send", "to": "eve", "payload": {"type": "answer", "id": "A10", "text": "There are 8 planets in our solar system."}}
  ]
}
