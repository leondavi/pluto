{
  "agent_id": "diana",
  "description": "Diana asks and answers questions, logs to shared transcript",
  "steps": [
    {"action": "wait_message", "from": "charlie", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A3] diana -> charlie: William Shakespeare wrote Romeo and Juliet.\n"},
    {"action": "release"},
    {"action": "send", "to": "charlie", "payload": {"type": "answer", "id": "A3", "text": "William Shakespeare wrote Romeo and Juliet."}},

    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[Q4] diana -> eve: How many continents are there?\n"},
    {"action": "release"},
    {"action": "send", "to": "eve", "payload": {"type": "question", "id": "Q4", "text": "How many continents are there?"}},

    {"action": "wait_message", "from": "eve", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A4] eve -> diana: There are 7 continents.\n"},
    {"action": "release"},

    {"action": "wait_message", "from": "bob", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A7] diana -> bob: Water boils at 100 degrees Celsius.\n"},
    {"action": "release"},
    {"action": "send", "to": "bob", "payload": {"type": "answer", "id": "A7", "text": "Water boils at 100 degrees Celsius."}},

    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[Q9] diana -> alice: What is the chemical symbol for gold?\n"},
    {"action": "release"},
    {"action": "send", "to": "alice", "payload": {"type": "question", "id": "Q9", "text": "What is the chemical symbol for gold?"}},

    {"action": "wait_message", "from": "alice", "timeout": 15},
    {"action": "acquire", "resource": "qa:transcript", "mode": "write", "ttl_ms": 10000},
    {"action": "append_file", "path": "${WORK_DIR}/transcript.txt", "content": "[A9] alice -> diana: The chemical symbol for gold is Au.\n"},
    {"action": "release"}
  ]
}
