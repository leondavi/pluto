{
  "agent_id": "reviewer-1",
  "description": "Wait for writer-1 to finish section 1, review it, append approval, signal writer-1",
  "steps": [
    {
      "action": "wait_message",
      "from": "writer-1",
      "timeout": 20
    },
    {
      "action": "acquire",
      "resource": "doc:section-1",
      "mode": "write",
      "ttl_ms": 15000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/section1.txt",
      "content": "Reviewed and approved by reviewer-1.\n"
    },
    {
      "action": "acquire",
      "resource": "doc:status-board",
      "mode": "write",
      "ttl_ms": 10000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/status.txt",
      "content": "reviewer-1: section 1 approved\n"
    },
    {
      "action": "release"
    },
    {
      "action": "release"
    },
    {
      "action": "send",
      "to": "writer-1",
      "payload": {"type": "review_complete", "section": 1, "approved": true}
    }
  ]
}
