{
  "agent_id": "reviewer-2",
  "description": "Wait for writer-2 to finish section 2, review it, append approval, signal writer-1",
  "steps": [
    {
      "action": "wait_message",
      "from": "writer-2",
      "timeout": 20
    },
    {
      "action": "acquire",
      "resource": "doc:section-2",
      "mode": "write",
      "ttl_ms": 15000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/section2.txt",
      "content": "Reviewed and approved by reviewer-2.\n"
    },
    {
      "action": "acquire",
      "resource": "doc:status-board",
      "mode": "write",
      "ttl_ms": 10000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/status.txt",
      "content": "reviewer-2: section 2 approved\n"
    },
    {
      "action": "release"
    },
    {
      "action": "release"
    },
    {
      "action": "send",
      "to": "writer-1",
      "payload": {"type": "review_complete", "section": 2, "approved": true}
    }
  ]
}
