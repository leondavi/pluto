{
  "agent_id": "reviewer-4",
  "description": "Wait for writer-4 to finish section 4, review it, append approval, signal writer-1",
  "steps": [
    {
      "action": "wait_message",
      "from": "writer-4",
      "timeout": 20
    },
    {
      "action": "acquire",
      "resource": "doc:section-4",
      "mode": "write",
      "ttl_ms": 15000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/section4.txt",
      "content": "Reviewed and approved by reviewer-4.\n"
    },
    {
      "action": "acquire",
      "resource": "doc:status-board",
      "mode": "write",
      "ttl_ms": 10000
    },
    {
      "action": "append_file",
      "path": "${WORK_DIR}/status.txt",
      "content": "reviewer-4: section 4 approved\n"
    },
    {
      "action": "release"
    },
    {
      "action": "release"
    },
    {
      "action": "send",
      "to": "writer-1",
      "payload": {"type": "review_complete", "section": 4, "approved": true}
    }
  ]
}
