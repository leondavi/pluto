{
  "name": "pipeline_document_assembly",
  "description": "8 agents (4 writers + 4 reviewers) coordinate to build a reviewed document. Writers chain-pass control, reviewers approve sections, writer-1 assembles the final output. Tests lock contention on shared status board, message passing chains, and multi-agent coordination.",
  "work_dir": "${TEMP_DIR}/pluto_demo_pipeline",
  "agents": [
    {"flow": "ag_writer1.json",   "start_delay_s": 0},
    {"flow": "ag_writer2.json",   "start_delay_s": 0},
    {"flow": "ag_writer3.json",   "start_delay_s": 0},
    {"flow": "ag_writer4.json",   "start_delay_s": 0},
    {"flow": "ag_reviewer1.json", "start_delay_s": 0},
    {"flow": "ag_reviewer2.json", "start_delay_s": 0},
    {"flow": "ag_reviewer3.json", "start_delay_s": 0},
    {"flow": "ag_reviewer4.json", "start_delay_s": 0}
  ],
  "timeout_s": 60,
  "assertions": [
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/section1.txt",
      "expected": ["writer-1", "reviewer-1"]
    },
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/section2.txt",
      "expected": ["writer-2", "reviewer-2"]
    },
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/section3.txt",
      "expected": ["writer-3", "reviewer-3"]
    },
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/section4.txt",
      "expected": ["writer-4", "reviewer-4"]
    },
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/final_document.txt",
      "expected": ["Assembled", "writer-1"]
    },
    {
      "type": "file_contains",
      "path": "${WORK_DIR}/status.txt",
      "expected": ["writer-1", "writer-2", "writer-3", "writer-4", "reviewer-1", "reviewer-2", "reviewer-3", "reviewer-4"]
    },
    {
      "type": "all_agents_completed"
    }
  ]
}
